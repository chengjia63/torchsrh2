#!/bin/sh
set -eu

matches=$(
    git diff --cached --name-only --diff-filter=ACMR -- "*.py" |
    while IFS= read -r path; do
        [ -n "$path" ] || continue
        git show ":$path" |
        awk -v path="$path" '
            {
                raw = $0
                line = $0
                sub(/#.*/, "", line)
                if (line ~ /pdb[[:space:]]*\.[[:space:]]*set_trace[[:space:]]*\([[:space:]]*\)/ ||
                    line ~ /breakpoint[[:space:]]*\([[:space:]]*\)/) {
                    print path ":" FNR ":" raw
                }
            }
        '
    done
)

if [ -n "$matches" ]; then
    red_bold='\033[1;31m'
    yellow_bold='\033[1;33m'
    reset='\033[0m'

    printf >&2 '\n'
    printf >&2 "${red_bold}####################${reset}\n"
    printf >&2 "${red_bold}#                  #${reset}\n"
    printf >&2 "${red_bold}# STOP  STOP  STOP #${reset}\n"
    printf >&2 "${red_bold}#                  #${reset}\n"
    printf >&2 "${red_bold}#  COMMIT BLOCKED  #${reset}\n"
    printf >&2 "${red_bold}#                  #${reset}\n"
    printf >&2 "${red_bold}# STOP  STOP  STOP #${reset}\n"
    printf >&2 "${red_bold}#                  #${reset}\n"
    printf >&2 "${red_bold}####################${reset}\n"
    printf >&2 "${yellow_bold}ACTIVE DEBUGGER CALLS FOUND${reset}\n"
    printf >&2 "${yellow_bold}Remove these before committing:${reset}\n"
    printf '%s\n\n' "$matches" >&2
    printf >&2 "To bypass: git commit --no-verify\n\n"
    exit 1
fi
